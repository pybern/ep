#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CD_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
REPO_ROOT="$(cd "$CD_ROOT/.." && pwd)"

TF_PLAN_RAW_PATH="tf.plan"
TF_PLAN_JSON_PATH="tf.json"
TF_RUNTIME_VARS_PATH="vars/$ENV_NAME/terraform-runtime.auto.tfvars"
SECRET_TFVARS_PATH="vars/$ENV_NAME/terraform-secret.tfvars"

pick_first() {
  for var_name in "$@"; do
    if [ -n "${!var_name:-}" ]; then
      printf '%s' "${!var_name}"
      return 0
    fi
  done
  return 1
}

tfvar_value() {
  local key="$1"
  local file="$2"
  if [ -f "$file" ]; then
    awk -F'=' -v key="$key" '
      $1 ~ "^[[:space:]]*" key "[[:space:]]*$" {
        value=$2
        sub(/^[[:space:]]*/, "", value)
        sub(/[[:space:]]*$/, "", value)
        gsub(/^"/, "", value)
        gsub(/"$/, "", value)
        print value
        exit
      }
    ' "$file"
  fi
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

cleanup_kaniko() {
  if [ -n "${KANIKO_POD_NAME:-}" ] && [ -n "${BUILD_NAMESPACE:-}" ]; then
    kubectl -n "$BUILD_NAMESPACE" delete pod "$KANIKO_POD_NAME" --ignore-not-found >/dev/null 2>&1 || true
  fi
  if [ -n "${KANIKO_SECRET_NAME:-}" ] && [ -n "${BUILD_NAMESPACE:-}" ]; then
    kubectl -n "$BUILD_NAMESPACE" delete secret "$KANIKO_SECRET_NAME" --ignore-not-found >/dev/null 2>&1 || true
  fi
}

build_and_push_local() {
  echo "=== Stage: Harbor Login ==="
  if command_exists docker; then
    echo "$REGISTRY_PASSWORD" | docker login "$REGISTRY_HOST" -u "$REGISTRY_USERNAME" --password-stdin
    echo "Harbor login complete."
    echo "=== Stage: Container Build ==="
    docker build -t "$IMAGE_REF" -f "$REPO_ROOT/Dockerfile" "$REPO_ROOT"
    echo "Container build complete: $IMAGE_REF"
    echo "=== Stage: Harbor Push ==="
    docker push "$IMAGE_REF"
    echo "Harbor push complete: $IMAGE_REF"
    return 0
  fi

  if command_exists podman; then
    echo "$REGISTRY_PASSWORD" | podman login "$REGISTRY_HOST" -u "$REGISTRY_USERNAME" --password-stdin
    echo "Harbor login complete."
    echo "=== Stage: Container Build ==="
    podman build -t "$IMAGE_REF" -f "$REPO_ROOT/Dockerfile" "$REPO_ROOT"
    echo "Container build complete: $IMAGE_REF"
    echo "=== Stage: Harbor Push ==="
    podman push "$IMAGE_REF"
    echo "Harbor push complete: $IMAGE_REF"
    return 0
  fi

  if command_exists buildah; then
    echo "$REGISTRY_PASSWORD" | buildah login "$REGISTRY_HOST" -u "$REGISTRY_USERNAME" --password-stdin
    echo "Harbor login complete."
    echo "=== Stage: Container Build ==="
    buildah bud -t "$IMAGE_REF" -f "$REPO_ROOT/Dockerfile" "$REPO_ROOT"
    echo "Container build complete: $IMAGE_REF"
    echo "=== Stage: Harbor Push ==="
    buildah push "$IMAGE_REF"
    echo "Harbor push complete: $IMAGE_REF"
    return 0
  fi

  return 1
}

build_and_push_kaniko() {
  if ! command_exists kubectl; then
    echo "ERROR: kubectl not found; cannot use in-cluster Kaniko fallback."
    exit 127
  fi

  K8S_CONFIG_RESOLVED="$(pick_first K8S_CONFIG_PATH KUBECONFIG K8S_CONFIG KUBE_CONFIG_PATH || true)"
  if [ -z "${K8S_CONFIG_RESOLVED:-}" ]; then
    K8S_CONFIG_RESOLVED="$(tfvar_value k8s_config "$SECRET_TFVARS_PATH")"
  fi
  if [ -z "${K8S_CONFIG_RESOLVED:-}" ]; then
    K8S_CONFIG_RESOLVED="$(tfvar_value k8s_config "vars/$ENV_NAME/terraform-config.tfvars")"
  fi
  if [ -n "${K8S_CONFIG_RESOLVED:-}" ]; then
    export KUBECONFIG="$K8S_CONFIG_RESOLVED"
    echo "Using KUBECONFIG for Kaniko fallback: $KUBECONFIG"
  fi

  if ! kubectl version --request-timeout=15s >/dev/null 2>&1; then
    echo "ERROR: kubectl cannot connect to cluster for Kaniko fallback."
    echo "Ensure kubeconfig is available to build stage (K8S_CONFIG_PATH/KUBECONFIG) and cluster access is permitted."
    exit 1
  fi

  BUILD_NAMESPACE="$(tfvar_value k8s_namespace "vars/$ENV_NAME/terraform-config.tfvars")"
  if [ -z "${BUILD_NAMESPACE:-}" ]; then
    echo "ERROR: k8s_namespace not found in vars/$ENV_NAME/terraform-config.tfvars"
    exit 1
  fi

  KANIKO_IMAGE="${KANIKO_IMAGE:-${REGISTRY_HOST}/dockerhub-proxy/kaniko-project/executor:debug}"
  KANIKO_POD_NAME="tois-kaniko-${ENV_NAME}-$(date +%s)"
  KANIKO_SECRET_NAME="tois-kaniko-regcred-$(date +%s)"
  KANIKO_READY_TIMEOUT="${KANIKO_READY_TIMEOUT:-420s}"
  trap cleanup_kaniko EXIT

  echo "=== Stage: Kaniko Build (Kubernetes) ==="
  echo "Using namespace: $BUILD_NAMESPACE"
  echo "Using Kaniko image: $KANIKO_IMAGE"

  DOCKER_CONFIG_JSON="$(cat <<EOF
{
  "auths": {
    "${REGISTRY_HOST}": {
      "auth": "$(printf '%s' "${REGISTRY_USERNAME}:${REGISTRY_PASSWORD}" | base64 | tr -d '\n')"
    }
  }
}
EOF
)"

  kubectl -n "$BUILD_NAMESPACE" create secret generic "$KANIKO_SECRET_NAME" --from-literal=.dockerconfigjson="$DOCKER_CONFIG_JSON" --type=kubernetes.io/dockerconfigjson >/dev/null

  cat <<EOF | kubectl -n "$BUILD_NAMESPACE" apply -f -
apiVersion: v1
kind: Pod
metadata:
  name: ${KANIKO_POD_NAME}
spec:
  restartPolicy: Never
  imagePullSecrets:
    - name: ${KANIKO_SECRET_NAME}
  containers:
    - name: kaniko
      image: ${KANIKO_IMAGE}
      command: ["/busybox/sh", "-c", "sleep 1800"]
      volumeMounts:
        - name: docker-config
          mountPath: /kaniko/.docker
  volumes:
    - name: docker-config
      secret:
        secretName: ${KANIKO_SECRET_NAME}
EOF

  if ! kubectl -n "$BUILD_NAMESPACE" wait --for=condition=Ready "pod/${KANIKO_POD_NAME}" --timeout="$KANIKO_READY_TIMEOUT"; then
    echo "ERROR: Kaniko pod did not become Ready within $KANIKO_READY_TIMEOUT"
    kubectl -n "$BUILD_NAMESPACE" describe pod "$KANIKO_POD_NAME" || true
    kubectl -n "$BUILD_NAMESPACE" get events --sort-by=.metadata.creationTimestamp | tail -n 80 || true
    kubectl -n "$BUILD_NAMESPACE" logs "$KANIKO_POD_NAME" -c kaniko --tail=200 || true
    exit 1
  fi
  kubectl -n "$BUILD_NAMESPACE" cp "$REPO_ROOT/." "${KANIKO_POD_NAME}:/workspace"

  kubectl -n "$BUILD_NAMESPACE" exec "$KANIKO_POD_NAME" -- /kaniko/executor \
    --context=dir:///workspace \
    --dockerfile=/workspace/Dockerfile \
    --destination="$IMAGE_REF" \
    --skip-tls-verify-registry="$REGISTRY_HOST"

  echo "Kaniko build and Harbor push complete: $IMAGE_REF"
}

REGISTRY_HOST="$(pick_first DOCKER_REGISTRY_HOST HARBOR_HOST TARGET_HARBOR_HOST SOURCE_HARBOR_HOST HARBOR_REGISTRY_HOST || true)"
REGISTRY_USERNAME="$(pick_first DOCKER_REGISTRY_USERNAME HARBOR_USERNAME TARGET_HARBOR_USERNAME SOURCE_HARBOR_USERNAME HARBOR_USER HARBOR_ACCOUNT TARGET_REPOSITORY_USERNAME SOURCE_REPOSITORY_USERNAME REPOSITORY_USERNAME || true)"
REGISTRY_PASSWORD="$(pick_first DOCKER_REGISTRY_PASSWORD HARBOR_PASSWORD TARGET_HARBOR_PASSWORD SOURCE_HARBOR_PASSWORD HARBOR_TOKEN TARGET_HARBOR_TOKEN SOURCE_HARBOR_TOKEN TARGET_REPOSITORY_PASSWORD SOURCE_REPOSITORY_PASSWORD REPOSITORY_PASSWORD || true)"
USE_SECRET_TFVARS=false

required_vars=(
  ENV_NAME
)
for v in "${required_vars[@]}"; do
  if [ -z "${!v:-}" ]; then
    echo "Missing required environment variable: $v"
    exit 1
  fi
done

if [ -f "$SECRET_TFVARS_PATH" ]; then
  first_line="$(sed -n '1p' "$SECRET_TFVARS_PATH" || true)"
  if [[ "$first_line" == \$ANSIBLE_VAULT* ]]; then
    if [ -n "${ANSIBLE_VAULT_SECRET_PATH:-}" ]; then
      if sh "$SCRIPT_DIR/ansible-vault" "decrypt" "$SECRET_TFVARS_PATH"; then
        USE_SECRET_TFVARS=true
      else
        echo "ERROR: Vault decrypt failed. Harbor robot credentials are required for image build/push."
        exit 1
      fi
    else
      echo "ERROR: terraform-secret.tfvars is encrypted but ANSIBLE_VAULT_SECRET_PATH is not set."
      exit 1
    fi
  else
    USE_SECRET_TFVARS=true
  fi
else
  echo "ERROR: No terraform-secret.tfvars found. Harbor robot credentials are required for image build/push."
  exit 1
fi

if [ -z "${REGISTRY_USERNAME:-}" ]; then
  REGISTRY_USERNAME="$(tfvar_value docker_registry_usr "$SECRET_TFVARS_PATH")"
fi
if [ -z "${REGISTRY_PASSWORD:-}" ]; then
  REGISTRY_PASSWORD="$(tfvar_value docker_registry_psw "$SECRET_TFVARS_PATH")"
fi

IMAGE_TAG="$(pick_first APPLICATION_INFRA_TAG application_infra_tag APP_INFRA_TAG APPLICATION_TAG APP_TAG IMAGE_TAG GIT_TAG CI_COMMIT_TAG || true)"
if [ -z "${IMAGE_TAG:-}" ]; then
  IMAGE_TAG="$(git -C "$REPO_ROOT" describe --tags --exact-match 2>/dev/null || git -C "$REPO_ROOT" rev-parse --short HEAD 2>/dev/null || true)"
fi
if [ -z "${IMAGE_TAG:-}" ]; then
  echo "ERROR: Missing deployment image tag."
  echo "Expected one of: APPLICATION_INFRA_TAG, application_infra_tag, APP_INFRA_TAG, APPLICATION_TAG, APP_TAG, IMAGE_TAG, GIT_TAG, CI_COMMIT_TAG"
  echo "Also attempted fallback from current git ref but could not resolve a tag/commit."
  exit 1
fi

if [ -n "${DOCKER_IMAGE_REPOSITORY:-}" ]; then
  IMAGE_REPOSITORY="$DOCKER_IMAGE_REPOSITORY"
elif [ -n "${HARBOR_IMAGE_REPOSITORY:-}" ]; then
  IMAGE_REPOSITORY="$HARBOR_IMAGE_REPOSITORY"
elif [ -n "${TARGET_HARBOR_IMAGE_REPOSITORY:-}" ]; then
  IMAGE_REPOSITORY="$TARGET_HARBOR_IMAGE_REPOSITORY"
elif [ -n "${SOURCE_HARBOR_IMAGE_REPOSITORY:-}" ]; then
  IMAGE_REPOSITORY="$SOURCE_HARBOR_IMAGE_REPOSITORY"
elif [ -n "${REGISTRY_HOST:-}" ]; then
  HARBOR_PROJECT_EFFECTIVE="$(pick_first HARBOR_PROJECT TARGET_HARBOR_PROJECT SOURCE_HARBOR_PROJECT || true)"
  HARBOR_REPOSITORY_EFFECTIVE="$(pick_first HARBOR_REPOSITORY TARGET_HARBOR_REPOSITORY SOURCE_HARBOR_REPOSITORY || true)"
  if [ -n "${HARBOR_PROJECT_EFFECTIVE:-}" ] && [ -n "${HARBOR_REPOSITORY_EFFECTIVE:-}" ]; then
    IMAGE_REPOSITORY="${REGISTRY_HOST}/${HARBOR_PROJECT_EFFECTIVE}/${HARBOR_REPOSITORY_EFFECTIVE}"
  fi
else
  IMAGE_REPOSITORY="$(awk -F'=' '/^[[:space:]]*image_repository[[:space:]]*=/{gsub(/"/, "", $2); gsub(/[[:space:]]/, "", $2); print $2; exit}' "vars/$ENV_NAME/terraform-config.tfvars")"
fi

if [ -z "${REGISTRY_HOST:-}" ]; then
  REGISTRY_HOST="$(tfvar_value docker_registry_host "vars/$ENV_NAME/terraform-config.tfvars")"
fi

if [ -z "${REGISTRY_HOST:-}" ] && [ -n "${IMAGE_REPOSITORY:-}" ]; then
  REGISTRY_HOST="${IMAGE_REPOSITORY%%/*}"
fi

echo "=== Stage: Prepare Deployment Inputs ==="
echo "Registry host resolved: ${REGISTRY_HOST:-<empty>}"
if [ -n "${REGISTRY_USERNAME:-}" ]; then
  echo "Registry username resolved."
else
  echo "Registry username not found in environment or secret tfvars."
fi
if [ -n "${REGISTRY_PASSWORD:-}" ]; then
  echo "Registry password resolved."
else
  echo "Registry password not found in environment or secret tfvars."
fi
echo "Image repository resolved: ${IMAGE_REPOSITORY:-<empty>}"
echo "Image tag resolved: ${IMAGE_TAG:-<empty>}"

if [ -z "${IMAGE_REPOSITORY:-}" ]; then
  echo "ERROR: image_repository is empty. Set it in terraform-config.tfvars or via environment."
  exit 1
fi
if [ -z "${REGISTRY_HOST:-}" ]; then
  echo "ERROR: docker_registry_host is empty."
  exit 1
fi
if [ -z "${REGISTRY_USERNAME:-}" ] || [ -z "${REGISTRY_PASSWORD:-}" ]; then
  echo "ERROR: Harbor robot credentials are required for Kubernetes imagePullSecret (docker_registry_usr/docker_registry_psw)."
  exit 1
fi

echo "Image reference selected for deployment: ${IMAGE_REPOSITORY}:${IMAGE_TAG}"
IMAGE_REF="${IMAGE_REPOSITORY}:${IMAGE_TAG}"

if ! build_and_push_local; then
  echo "No local container builder found. Falling back to Kaniko on Kubernetes."
  build_and_push_kaniko
fi

: > "$TF_RUNTIME_VARS_PATH"
echo "env_name=\"$ENV_NAME\"" >> "$TF_RUNTIME_VARS_PATH"
if [ -n "${K8S_CONFIG_PATH:-}" ]; then
  echo "k8s_config=\"$K8S_CONFIG_PATH\"" >> "$TF_RUNTIME_VARS_PATH"
fi
if [ -n "${IMAGE_REPOSITORY:-}" ]; then
  echo "image_repository=\"$IMAGE_REPOSITORY\"" >> "$TF_RUNTIME_VARS_PATH"
fi
echo "image_tag=\"$IMAGE_TAG\"" >> "$TF_RUNTIME_VARS_PATH"
if [ -n "${REGISTRY_HOST:-}" ]; then
  echo "docker_registry_host=\"$REGISTRY_HOST\"" >> "$TF_RUNTIME_VARS_PATH"
fi
if [ -n "${REGISTRY_USERNAME:-}" ]; then
  echo "docker_registry_usr=\"$REGISTRY_USERNAME\"" >> "$TF_RUNTIME_VARS_PATH"
fi
if [ -n "${REGISTRY_PASSWORD:-}" ]; then
  echo "docker_registry_psw=\"$REGISTRY_PASSWORD\"" >> "$TF_RUNTIME_VARS_PATH"
fi
echo "create_image_pull_secret=true" >> "$TF_RUNTIME_VARS_PATH"

echo "=== Stage: Terraform Plan ==="
terraform_args=(
  "-var-file=vars/$ENV_NAME/terraform-config.tfvars"
  "-var-file=$TF_RUNTIME_VARS_PATH"
)
if [ "$USE_SECRET_TFVARS" = true ]; then
  terraform_args+=("-var-file=$SECRET_TFVARS_PATH")
fi

terraform plan --out "$TF_PLAN_RAW_PATH" "${terraform_args[@]}"
terraform show -json "$TF_PLAN_RAW_PATH" > "$TF_PLAN_JSON_PATH"
terraform graph -plan="$TF_PLAN_RAW_PATH"
echo "Terraform plan complete: $TF_PLAN_RAW_PATH"
