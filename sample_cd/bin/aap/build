REGISTRY_PASSWORD="$(pick_first DOCKER_REGISTRY_PASSWORD HARBOR_PASSWORD || true)"
if [ -z "${REGISTRY_USERNAME:-}" ]; then
  REGISTRY_USERNAME="$(tfvar_value docker_registry_usr "$SECRET_TFVARS_PATH")"
fi
if [ -z "${REGISTRY_PASSWORD:-}" ]; then
  REGISTRY_PASSWORD="$(tfvar_value docker_registry_psw "$SECRET_TFVARS_PATH")"
fi

if [ -z "${REGISTRY_USERNAME:-}" ] || [ -z "${REGISTRY_PASSWORD:-}" ]; then
  echo "Missing Harbor credentials (docker_registry_usr/docker_registry_psw)."
  exit 1
fi

echo "Deploy-only mode: image build is external."
echo "Using image: ${IMAGE_REPOSITORY}:${IMAGE_TAG}"

: > "$TF_RUNTIME_VARS_PATH"
echo "env_name=\"$ENV_NAME\"" >> "$TF_RUNTIME_VARS_PATH"
if [ -n "${K8S_CONFIG_PATH:-}" ]; then
  echo "k8s_config=\"$K8S_CONFIG_PATH\"" >> "$TF_RUNTIME_VARS_PATH"
fi
echo "image_repository=\"$IMAGE_REPOSITORY\"" >> "$TF_RUNTIME_VARS_PATH"
echo "image_tag=\"$IMAGE_TAG\"" >> "$TF_RUNTIME_VARS_PATH"
echo "docker_registry_host=\"$REGISTRY_HOST\"" >> "$TF_RUNTIME_VARS_PATH"
echo "docker_registry_usr=\"$REGISTRY_USERNAME\"" >> "$TF_RUNTIME_VARS_PATH"
echo "docker_registry_psw=\"$REGISTRY_PASSWORD\"" >> "$TF_RUNTIME_VARS_PATH"

terraform plan -lock=false --out "$TF_PLAN_RAW_PATH" \
  -var-file="$CONFIG_TFVARS_PATH" \
  -var-file="$SECRET_TFVARS_PATH" \
  -var-file="$TF_RUNTIME_VARS_PATH"

terraform show -json "$TF_PLAN_RAW_PATH" > "$TF_PLAN_JSON_PATH"
terraform graph -plan="$TF_PLAN_RAW_PATH"
#!/bin/bash
set -euo pipefail

TF_PLAN_RAW_PATH="tf.plan"
TF_PLAN_JSON_PATH="tf.json"
TF_RUNTIME_VARS_PATH="vars/$ENV_NAME/terraform-runtime.auto.tfvars"
SECRET_TFVARS_PATH="vars/$ENV_NAME/terraform-secret.tfvars"
CONFIG_TFVARS_PATH="vars/$ENV_NAME/terraform-config.tfvars"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"

pick_first() {
  for var_name in "$@"; do
    if [ -n "${!var_name:-}" ]; then
      printf '%s' "${!var_name}"
      return 0
    fi
  done
  return 1
}

tfvar_value() {
  local key="$1"
  local file="$2"
  if [ ! -f "$file" ]; then
    return 0
  fi
  awk -F'=' -v key="$key" '
    $1 ~ "^[[:space:]]*" key "[[:space:]]*$" {
      value=$2
      sub(/^[[:space:]]*/, "", value)
      sub(/[[:space:]]*$/, "", value)
      gsub(/^"/, "", value)
      gsub(/"$/, "", value)
      print value
      exit
    }
  ' "$file"
}

if [ -z "${ENV_NAME:-}" ]; then
  echo "Missing required environment variable: ENV_NAME"
  exit 1
fi

if [ ! -f "$SECRET_TFVARS_PATH" ]; then
  echo "Missing secret tfvars: $SECRET_TFVARS_PATH"
  exit 1
fi

first_line="$(sed -n '1p' "$SECRET_TFVARS_PATH" || true)"
if [[ "$first_line" == \$ANSIBLE_VAULT* ]]; then
  if [ -z "${ANSIBLE_VAULT_SECRET_PATH:-}" ]; then
    echo "terraform-secret.tfvars is encrypted but ANSIBLE_VAULT_SECRET_PATH is not set."
    exit 1
  fi
  sh "$SCRIPT_DIR/ansible-vault" decrypt "$SECRET_TFVARS_PATH"
fi

IMAGE_TAG="$(pick_first APPLICATION_INFRA_TAG application_infra_tag APP_TAG IMAGE_TAG CI_COMMIT_TAG || true)"
if [ -z "${IMAGE_TAG:-}" ]; then
  echo "Missing image tag. Set APPLICATION_INFRA_TAG (or IMAGE_TAG)."
  exit 1
fi

IMAGE_REPOSITORY="$(pick_first DOCKER_IMAGE_REPOSITORY HARBOR_IMAGE_REPOSITORY || true)"
if [ -z "${IMAGE_REPOSITORY:-}" ]; then
  IMAGE_REPOSITORY="$(tfvar_value image_repository "$CONFIG_TFVARS_PATH")"
fi
if [ -z "${IMAGE_REPOSITORY:-}" ]; then
  echo "Missing image_repository. Set in $CONFIG_TFVARS_PATH or DOCKER_IMAGE_REPOSITORY."
  exit 1
fi

REGISTRY_HOST="$(pick_first DOCKER_REGISTRY_HOST HARBOR_HOST || true)"
if [ -z "${REGISTRY_HOST:-}" ]; then
  REGISTRY_HOST="$(tfvar_value docker_registry_host "$CONFIG_TFVARS_PATH")"
fi
if [ -z "${REGISTRY_HOST:-}" ]; then
  REGISTRY_HOST="${IMAGE_REPOSITORY%%/*}"
fi

REGISTRY_USERNAME="$(pick_first DOCKER_REGISTRY_USERNAME HARBOR_USERNAME || true)"
REGISTRY_PASSWORD="$(pick_first DOCKER_REGISTRY_PASSWORD HARBOR_PASSWORD || true)"
if [ -z "${REGISTRY_USERNAME:-}" ]; then
  REGISTRY_USERNAME="$(tfvar_value docker_registry_usr "$SECRET_TFVARS_PATH")"
fi
if [ -z "${REGISTRY_PASSWORD:-}" ]; then
  REGISTRY_PASSWORD="$(tfvar_value docker_registry_psw "$SECRET_TFVARS_PATH")"
fi

if [ -z "${REGISTRY_USERNAME:-}" ] || [ -z "${REGISTRY_PASSWORD:-}" ]; then
  echo "Missing Harbor credentials (docker_registry_usr/docker_registry_psw)."
  exit 1
fi

IMAGE_REF="${IMAGE_REPOSITORY}:${IMAGE_TAG}"
echo "Building and pushing image: $IMAGE_REF"

if command -v docker >/dev/null 2>&1; then
  docker login "$REGISTRY_HOST" -u "$REGISTRY_USERNAME" -p "$REGISTRY_PASSWORD"
  docker build -t "$IMAGE_REF" "$REPO_ROOT"
  docker push "$IMAGE_REF"
elif command -v podman >/dev/null 2>&1; then
  podman login "$REGISTRY_HOST" -u "$REGISTRY_USERNAME" -p "$REGISTRY_PASSWORD"
  podman build -t "$IMAGE_REF" "$REPO_ROOT"
  podman push "$IMAGE_REF"
elif command -v buildah >/dev/null 2>&1; then
  buildah login -u "$REGISTRY_USERNAME" -p "$REGISTRY_PASSWORD" "$REGISTRY_HOST"
  buildah bud -t "$IMAGE_REF" "$REPO_ROOT"
  buildah push "$IMAGE_REF"
else
  echo "No supported image builder found (docker/podman/buildah)."
  exit 1
fi

: > "$TF_RUNTIME_VARS_PATH"
echo "env_name=\"$ENV_NAME\"" >> "$TF_RUNTIME_VARS_PATH"
if [ -n "${K8S_CONFIG_PATH:-}" ]; then
  echo "k8s_config=\"$K8S_CONFIG_PATH\"" >> "$TF_RUNTIME_VARS_PATH"
fi
echo "image_repository=\"$IMAGE_REPOSITORY\"" >> "$TF_RUNTIME_VARS_PATH"
echo "image_tag=\"$IMAGE_TAG\"" >> "$TF_RUNTIME_VARS_PATH"
echo "docker_registry_host=\"$REGISTRY_HOST\"" >> "$TF_RUNTIME_VARS_PATH"
echo "docker_registry_usr=\"$REGISTRY_USERNAME\"" >> "$TF_RUNTIME_VARS_PATH"
echo "docker_registry_psw=\"$REGISTRY_PASSWORD\"" >> "$TF_RUNTIME_VARS_PATH"

terraform plan -lock=false --out "$TF_PLAN_RAW_PATH" \
  -var-file="$CONFIG_TFVARS_PATH" \
  -var-file="$SECRET_TFVARS_PATH" \
  -var-file="$TF_RUNTIME_VARS_PATH"

terraform show -json "$TF_PLAN_RAW_PATH" > "$TF_PLAN_JSON_PATH"
terraform graph -plan="$TF_PLAN_RAW_PATH"
