fi
if [ -z "${IMAGE_TAG:-}" ]; then
  echo "Missing image tag. Set application_infra_tag in payload or IMAGE_TAG/APPLICATION_INFRA_TAG."
  exit 1
fi
export APPLICATION_INFRA_TAG="$IMAGE_TAG"
export APP_TAG="$IMAGE_TAG"

IMAGE_REPOSITORY="$(pick_first DOCKER_IMAGE_REPOSITORY HARBOR_IMAGE_REPOSITORY || true)"
if [ -z "${IMAGE_REPOSITORY:-}" ]; then
  IMAGE_REPOSITORY="dpsauatdk01.intra.hkma.gov.hk:8443/dockerhub-proxy/syedayanali28/tois:latest"
fi

REGISTRY_HOST="$(pick_first DOCKER_REGISTRY_HOST HARBOR_HOST || true)"
if [ -z "${REGISTRY_HOST:-}" ]; then
  REGISTRY_HOST="${IMAGE_REPOSITORY%%/*}"
fi

