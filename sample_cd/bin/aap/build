#!/bin/bash
set -e

TF_PLAN_RAW_PATH="tf.plan"
TF_PLAN_JSON_PATH="tf.json"

sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/terraform-secret.tfvars"
sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/admin_gui_session_conf"
sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/portal_session_conf"
sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/admin_gui_auth_conf"
sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/tls.key"
sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/ingress.key"
sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/license.json"

echo "k8s_config=\"$K8S_CONFIG_PATH\"" >> vars/$ENV_NAME/terraform-secret.tfvars
echo "env_name=\"$ENV_NAME\"" >> vars/$ENV_NAME/terraform-config.tfvars

terraform plan --out $TF_PLAN_RAW_PATH -var-file=vars/$ENV_NAME/terraform-config.tfvars -var-file=./vars/$ENV_NAME/terraform-secret.tfvars
terraform show -json $TF_PLAN_RAW_PATH > $TF_PLAN_JSON_PATH

terraform graph -plan=$TF_PLAN_RAW_PATH 
#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CD_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
REPO_ROOT="$(cd "$CD_ROOT/.." && pwd)"

TF_PLAN_RAW_PATH="tf.plan"
TF_PLAN_JSON_PATH="tf.json"
TF_RUNTIME_VARS_PATH="vars/$ENV_NAME/terraform-runtime.auto.tfvars"
SECRET_TFVARS_PATH="vars/$ENV_NAME/terraform-secret.tfvars"

pick_first() {
  for var_name in "$@"; do
    if [ -n "${!var_name:-}" ]; then
      printf '%s' "${!var_name}"
      return 0
    fi
  done
  return 1
}

tfvar_value() {
  local key="$1"
  local file="$2"
  if [ -f "$file" ]; then
    awk -F'=' -v key="$key" '
      $1 ~ "^[[:space:]]*" key "[[:space:]]*$" {
        value=$2
        sub(/^[[:space:]]*/, "", value)
        sub(/[[:space:]]*$/, "", value)
        gsub(/^"/, "", value)
        gsub(/"$/, "", value)
        print value
        exit
      }
    ' "$file"
  fi
}

harbor_preflight_check() {
  if ! command -v curl >/dev/null 2>&1; then
    echo "ERROR: curl is required for Harbor preflight checks."
    exit 1
  fi

  local image_path
  image_path="${IMAGE_REPOSITORY#${REGISTRY_HOST}/}"
  if [[ "$image_path" != */* ]]; then
    echo "ERROR: image_repository must include Harbor project/repository path: $IMAGE_REPOSITORY"
    exit 1
  fi
  local harbor_project harbor_repo
  harbor_project="${image_path%%/*}"
  harbor_repo="${image_path#*/}"

  if [ -z "$harbor_project" ] || [ -z "$harbor_repo" ]; then
    echo "ERROR: Cannot parse Harbor project/repository from image_repository: $IMAGE_REPOSITORY"
    exit 1
  fi

  local harbor_api
  harbor_api="https://${REGISTRY_HOST}/api/v2.0"

  local auth_code tag_code repo_encoded
  auth_code="$(curl -k -sS -o /dev/null -w "%{http_code}" --user "${REGISTRY_USERNAME}:${REGISTRY_PASSWORD}" "${harbor_api}/projects/${harbor_project}")"
  if [ "$auth_code" -ne 200 ]; then
    echo "ERROR: Harbor auth/project check failed for project '${harbor_project}' (HTTP ${auth_code})."
    exit 1
  fi

  repo_encoded="${harbor_repo//\//%2F}"
  tag_code="$(curl -k -sS -o /dev/null -w "%{http_code}" --user "${REGISTRY_USERNAME}:${REGISTRY_PASSWORD}" "${harbor_api}/projects/${harbor_project}/repositories/${repo_encoded}/artifacts/${IMAGE_TAG}")"
  if [ "$tag_code" -ne 200 ]; then
    echo "ERROR: Harbor image tag not found or inaccessible: ${IMAGE_REPOSITORY}:${IMAGE_TAG} (HTTP ${tag_code})."
    exit 1
  fi

  echo "Harbor preflight passed: ${IMAGE_REPOSITORY}:${IMAGE_TAG} exists and is accessible."
}

REGISTRY_HOST="$(pick_first DOCKER_REGISTRY_HOST HARBOR_HOST TARGET_HARBOR_HOST SOURCE_HARBOR_HOST HARBOR_REGISTRY_HOST || true)"
REGISTRY_USERNAME="$(pick_first DOCKER_REGISTRY_USERNAME HARBOR_USERNAME TARGET_HARBOR_USERNAME SOURCE_HARBOR_USERNAME HARBOR_USER HARBOR_ACCOUNT TARGET_REPOSITORY_USERNAME SOURCE_REPOSITORY_USERNAME REPOSITORY_USERNAME || true)"
REGISTRY_PASSWORD="$(pick_first DOCKER_REGISTRY_PASSWORD HARBOR_PASSWORD TARGET_HARBOR_PASSWORD SOURCE_HARBOR_PASSWORD HARBOR_TOKEN TARGET_HARBOR_TOKEN SOURCE_HARBOR_TOKEN TARGET_REPOSITORY_PASSWORD SOURCE_REPOSITORY_PASSWORD REPOSITORY_PASSWORD || true)"
USE_SECRET_TFVARS=false

required_vars=(
  ENV_NAME
)
for v in "${required_vars[@]}"; do
  if [ -z "${!v:-}" ]; then
    echo "Missing required environment variable: $v"
    exit 1
  fi
done

if [ -f "$SECRET_TFVARS_PATH" ]; then
  first_line="$(sed -n '1p' "$SECRET_TFVARS_PATH" || true)"
  if [[ "$first_line" == \$ANSIBLE_VAULT* ]]; then
    if [ -n "${ANSIBLE_VAULT_SECRET_PATH:-}" ]; then
      if sh "$SCRIPT_DIR/ansible-vault" "decrypt" "$SECRET_TFVARS_PATH"; then
        USE_SECRET_TFVARS=true
      else
        echo "ERROR: Vault decrypt failed. Harbor robot credentials are required for imagePullSecret."
        exit 1
      fi
    else
      echo "ERROR: terraform-secret.tfvars is encrypted but ANSIBLE_VAULT_SECRET_PATH is not set."
      exit 1
    fi
  else
    USE_SECRET_TFVARS=true
  fi
else
  echo "ERROR: No terraform-secret.tfvars found. Harbor robot credentials are required for imagePullSecret."
  exit 1
fi

if [ -z "${REGISTRY_USERNAME:-}" ]; then
  REGISTRY_USERNAME="$(tfvar_value docker_registry_usr "$SECRET_TFVARS_PATH")"
fi
if [ -z "${REGISTRY_PASSWORD:-}" ]; then
  REGISTRY_PASSWORD="$(tfvar_value docker_registry_psw "$SECRET_TFVARS_PATH")"
fi

IMAGE_TAG="$(pick_first APPLICATION_INFRA_TAG application_infra_tag APP_INFRA_TAG APPLICATION_TAG APP_TAG IMAGE_TAG GIT_TAG CI_COMMIT_TAG || true)"
if [ -z "${IMAGE_TAG:-}" ]; then
  IMAGE_TAG="${DEFAULT_IMAGE_TAG:-dev_v0.0.26}"
  echo "No deployment tag env var found. Falling back to fixed default tag: $IMAGE_TAG"
fi

if [ -z "${IMAGE_TAG:-}" ]; then
  echo "ERROR: Missing deployment image tag and unable to resolve git fallback."
  exit 1
fi

if [ -n "${DOCKER_IMAGE_REPOSITORY:-}" ]; then
  IMAGE_REPOSITORY="$DOCKER_IMAGE_REPOSITORY"
elif [ -n "${HARBOR_IMAGE_REPOSITORY:-}" ]; then
  IMAGE_REPOSITORY="$HARBOR_IMAGE_REPOSITORY"
elif [ -n "${TARGET_HARBOR_IMAGE_REPOSITORY:-}" ]; then
  IMAGE_REPOSITORY="$TARGET_HARBOR_IMAGE_REPOSITORY"
elif [ -n "${SOURCE_HARBOR_IMAGE_REPOSITORY:-}" ]; then
  IMAGE_REPOSITORY="$SOURCE_HARBOR_IMAGE_REPOSITORY"
elif [ -n "${REGISTRY_HOST:-}" ]; then
  HARBOR_PROJECT_EFFECTIVE="$(pick_first HARBOR_PROJECT TARGET_HARBOR_PROJECT SOURCE_HARBOR_PROJECT || true)"
  HARBOR_REPOSITORY_EFFECTIVE="$(pick_first HARBOR_REPOSITORY TARGET_HARBOR_REPOSITORY SOURCE_HARBOR_REPOSITORY || true)"
  if [ -n "${HARBOR_PROJECT_EFFECTIVE:-}" ] && [ -n "${HARBOR_REPOSITORY_EFFECTIVE:-}" ]; then
    IMAGE_REPOSITORY="${REGISTRY_HOST}/${HARBOR_PROJECT_EFFECTIVE}/${HARBOR_REPOSITORY_EFFECTIVE}"
  fi
else
  IMAGE_REPOSITORY="$(awk -F'=' '/^[[:space:]]*image_repository[[:space:]]*=/{gsub(/"/, "", $2); gsub(/[[:space:]]/, "", $2); print $2; exit}' "vars/$ENV_NAME/terraform-config.tfvars")"
fi

if [ -z "${REGISTRY_HOST:-}" ]; then
  REGISTRY_HOST="$(tfvar_value docker_registry_host "vars/$ENV_NAME/terraform-config.tfvars")"
fi

if [ -z "${REGISTRY_HOST:-}" ] && [ -n "${IMAGE_REPOSITORY:-}" ]; then
  REGISTRY_HOST="${IMAGE_REPOSITORY%%/*}"
fi

echo "=== Stage: Prepare Deployment Inputs ==="
echo "Registry host resolved: ${REGISTRY_HOST:-<empty>}"
if [ -n "${REGISTRY_USERNAME:-}" ]; then
  echo "Registry username resolved."
else
  echo "Registry username not found in environment or secret tfvars."
fi
if [ -n "${REGISTRY_PASSWORD:-}" ]; then
  echo "Registry password resolved."
else
  echo "Registry password not found in environment or secret tfvars."
fi
echo "Image repository resolved: ${IMAGE_REPOSITORY:-<empty>}"
echo "Image tag resolved: ${IMAGE_TAG:-<empty>}"

if [ -z "${IMAGE_REPOSITORY:-}" ]; then
  echo "ERROR: image_repository is empty. Set it in terraform-config.tfvars or via environment."
  exit 1
fi
if [ -z "${REGISTRY_HOST:-}" ]; then
  echo "ERROR: docker_registry_host is empty."
  exit 1
fi
if [ -z "${REGISTRY_USERNAME:-}" ] || [ -z "${REGISTRY_PASSWORD:-}" ]; then
  echo "ERROR: Harbor robot credentials are required for Kubernetes imagePullSecret (docker_registry_usr/docker_registry_psw)."
  exit 1
fi

echo "Image reference selected for deployment: ${IMAGE_REPOSITORY}:${IMAGE_TAG}"
echo "Image build/push is handled outside this script."

echo "=== Stage: Harbor Preflight ==="
harbor_preflight_check

: > "$TF_RUNTIME_VARS_PATH"
echo "env_name=\"$ENV_NAME\"" >> "$TF_RUNTIME_VARS_PATH"
if [ -n "${K8S_CONFIG_PATH:-}" ]; then
  echo "k8s_config=\"$K8S_CONFIG_PATH\"" >> "$TF_RUNTIME_VARS_PATH"
fi
if [ -n "${IMAGE_REPOSITORY:-}" ]; then
  echo "image_repository=\"$IMAGE_REPOSITORY\"" >> "$TF_RUNTIME_VARS_PATH"
fi
echo "image_tag=\"$IMAGE_TAG\"" >> "$TF_RUNTIME_VARS_PATH"
if [ -n "${REGISTRY_HOST:-}" ]; then
  echo "docker_registry_host=\"$REGISTRY_HOST\"" >> "$TF_RUNTIME_VARS_PATH"
fi
if [ -n "${REGISTRY_USERNAME:-}" ]; then
  echo "docker_registry_usr=\"$REGISTRY_USERNAME\"" >> "$TF_RUNTIME_VARS_PATH"
fi
if [ -n "${REGISTRY_PASSWORD:-}" ]; then
  echo "docker_registry_psw=\"$REGISTRY_PASSWORD\"" >> "$TF_RUNTIME_VARS_PATH"
fi
echo "create_image_pull_secret=true" >> "$TF_RUNTIME_VARS_PATH"

echo "=== Stage: Terraform Plan ==="
terraform_args=(
  "-var-file=vars/$ENV_NAME/terraform-config.tfvars"
  "-var-file=$TF_RUNTIME_VARS_PATH"
)
if [ "$USE_SECRET_TFVARS" = true ]; then
  terraform_args+=("-var-file=$SECRET_TFVARS_PATH")
fi

terraform plan -lock=false --out "$TF_PLAN_RAW_PATH" "${terraform_args[@]}"

terraform show -json "$TF_PLAN_RAW_PATH" > "$TF_PLAN_JSON_PATH"
terraform graph -plan="$TF_PLAN_RAW_PATH"
echo "Terraform plan complete: $TF_PLAN_RAW_PATH"
