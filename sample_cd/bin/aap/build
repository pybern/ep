#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CD_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
TF_WORK_DIR="$CD_ROOT/tf_app"

TF_PLAN_RAW_PATH="$TF_WORK_DIR/tf.plan"
TF_PLAN_JSON_PATH="$TF_WORK_DIR/tf.json"
TF_RUNTIME_VARS_PATH="$TF_WORK_DIR/terraform-runtime.auto.tfvars"
CONFIG_TFVARS_PATH="$CD_ROOT/vars/$ENV_NAME/terraform-config.tfvars"
SECRET_TFVARS_PATH="$CD_ROOT/vars/$ENV_NAME/terraform-secret.tfvars"

pick_first() {
  for var_name in "$@"; do
    if [ -n "${!var_name:-}" ]; then
      printf '%s' "${!var_name}"
      return 0
    fi
  done
  return 1
}

tfvar_value() {
  local key="$1"
  local file="$2"
  if [ ! -f "$file" ]; then
    return 0
  fi
  awk -F'=' -v key="$key" '
    $1 ~ "^[[:space:]]*" key "[[:space:]]*$" {
      value=$2
      sub(/^[[:space:]]*/, "", value)
      sub(/[[:space:]]*$/, "", value)
      gsub(/^"/, "", value)
      gsub(/"$/, "", value)
      print value
      exit
    }
  ' "$file"
}

payload_tag() {
  local payload="$1"
  local py_bin=""
  if command -v python >/dev/null 2>&1; then
    py_bin="python"
  elif command -v python3 >/dev/null 2>&1; then
    py_bin="python3"
  fi
  if [ -z "$py_bin" ] || [ -z "$payload" ]; then
    return 0
  fi
  PAYLOAD="$payload" "$py_bin" -c "import os,re; p=os.environ.get('PAYLOAD',''); m=re.search(r\"application_infra_tag\\s*[:=]\\s*['\\\"]?([^'\\\",}\\s]+)\", p); print(m.group(1) if m else '')" 2>/dev/null
}

if [ -z "${ENV_NAME:-}" ]; then
  echo "Missing required environment variable: ENV_NAME"
  exit 1
fi

if [ ! -f "$SECRET_TFVARS_PATH" ]; then
  echo "Missing secret tfvars: $SECRET_TFVARS_PATH"
  exit 1
fi

# Decrypt only when file is actually vault-encrypted.
first_line="$(sed -n '1p' "$SECRET_TFVARS_PATH" || true)"
if [[ "$first_line" == \$ANSIBLE_VAULT* ]]; then
  if [ -z "${ANSIBLE_VAULT_SECRET_PATH:-}" ]; then
    echo "terraform-secret.tfvars is encrypted but ANSIBLE_VAULT_SECRET_PATH is not set."
    exit 1
  fi
  if ! sh "$SCRIPT_DIR/ansible-vault" decrypt "$SECRET_TFVARS_PATH"; then
    echo "Vault decrypt failed for terraform-secret.tfvars."
    echo "Use plaintext tfvars or provide matching vault secret in AAP."
    exit 1
  fi
fi

# Resolve image tag from env, AAP payload text, then config fallback.
IMAGE_TAG="$(pick_first APPLICATION_INFRA_TAG application_infra_tag APP_INFRA_TAG APPLICATION_TAG APP_TAG IMAGE_TAG CI_COMMIT_TAG || true)"
if [ -z "${IMAGE_TAG:-}" ]; then
  payload="${APPLICATIONS:-${applications:-${APPLICATION:-${application:-}}}}"
  IMAGE_TAG="$(payload_tag "$payload" || true)"
fi
if [ -z "${IMAGE_TAG:-}" ]; then
  IMAGE_TAG="$(tfvar_value image_tag "$CONFIG_TFVARS_PATH")"
fi
if [ -z "${IMAGE_TAG:-}" ]; then
  echo "Missing image tag. Provide application_infra_tag in AAP launch payload."
  exit 1
fi
export APPLICATION_INFRA_TAG="$IMAGE_TAG"
export APP_TAG="$IMAGE_TAG"

# Resolve image repository and registry.
IMAGE_REPOSITORY="$(pick_first DOCKER_IMAGE_REPOSITORY HARBOR_IMAGE_REPOSITORY || true)"
if [ -z "${IMAGE_REPOSITORY:-}" ]; then
  IMAGE_REPOSITORY="$(tfvar_value image_repository "$CONFIG_TFVARS_PATH")"
fi
if [ -z "${IMAGE_REPOSITORY:-}" ]; then
  echo "Missing image_repository in $CONFIG_TFVARS_PATH."
  exit 1
fi

REGISTRY_HOST="$(pick_first DOCKER_REGISTRY_HOST HARBOR_HOST || true)"
if [ -z "${REGISTRY_HOST:-}" ]; then
  REGISTRY_HOST="$(tfvar_value docker_registry_host "$CONFIG_TFVARS_PATH")"
fi
if [ -z "${REGISTRY_HOST:-}" ]; then
  REGISTRY_HOST="${IMAGE_REPOSITORY%%/*}"
fi

# Resolve pull-secret credentials from env first, then tfvars.
REGISTRY_USERNAME="$(pick_first DOCKER_REGISTRY_USERNAME HARBOR_USERNAME || true)"
REGISTRY_PASSWORD="$(pick_first DOCKER_REGISTRY_PASSWORD HARBOR_PASSWORD || true)"
if [ -z "${REGISTRY_USERNAME:-}" ]; then
  REGISTRY_USERNAME="$(tfvar_value docker_registry_usr "$SECRET_TFVARS_PATH")"
fi
if [ -z "${REGISTRY_PASSWORD:-}" ]; then
  REGISTRY_PASSWORD="$(tfvar_value docker_registry_psw "$SECRET_TFVARS_PATH")"
fi

if [ -z "${REGISTRY_USERNAME:-}" ] || [ -z "${REGISTRY_PASSWORD:-}" ]; then
  echo "Missing Harbor credentials (docker_registry_usr/docker_registry_psw)."
  exit 1
fi

echo "Deploy-only mode: image build is external."
echo "Using image: ${IMAGE_REPOSITORY}:${IMAGE_TAG}"

: > "$TF_RUNTIME_VARS_PATH"
echo "env_name=\"$ENV_NAME\"" >> "$TF_RUNTIME_VARS_PATH"
if [ -n "${K8S_CONFIG_PATH:-}" ]; then
  echo "k8s_config=\"$K8S_CONFIG_PATH\"" >> "$TF_RUNTIME_VARS_PATH"
fi
echo "image_repository=\"$IMAGE_REPOSITORY\"" >> "$TF_RUNTIME_VARS_PATH"
echo "image_tag=\"$IMAGE_TAG\"" >> "$TF_RUNTIME_VARS_PATH"
echo "docker_registry_host=\"$REGISTRY_HOST\"" >> "$TF_RUNTIME_VARS_PATH"
echo "docker_registry_usr=\"$REGISTRY_USERNAME\"" >> "$TF_RUNTIME_VARS_PATH"
echo "docker_registry_psw=\"$REGISTRY_PASSWORD\"" >> "$TF_RUNTIME_VARS_PATH"

terraform -chdir="$TF_WORK_DIR" plan -lock=false --out "$TF_PLAN_RAW_PATH" \
  -var-file="$CONFIG_TFVARS_PATH" \
  -var-file="$SECRET_TFVARS_PATH" \
  -var-file="$TF_RUNTIME_VARS_PATH"

terraform -chdir="$TF_WORK_DIR" show -json "$TF_PLAN_RAW_PATH" > "$TF_PLAN_JSON_PATH"
terraform -chdir="$TF_WORK_DIR" graph -plan="$TF_PLAN_RAW_PATH"
exit 0
#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CD_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
